{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://config/schemas/map.schema.json",
  "title": "Medieval Rebellion - Game Map Schema v0.2",
  "description": "V0.2 迭代2：地图编辑器 .map.json 官方 JSON Schema 校验定义。保存/加载/工坊导入 均执行该校验。",
  "type": "object",
  "required": ["version", "map_id", "display_name", "tilesets", "layers", "entities", "objectives"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string", "description": "项目语义版本，如 0.2.0" },
    "map_id": { "type": "string", "minLength": 1, "description": "地图唯一ID，如 farm_01" },
    "display_name": { "type": "string", "description": "显示名" },
    "tilesets": {
      "type": "array",
      "description": "使用到的官方图块集 ID 与 first_id",
      "items": {
        "type": "object",
        "required": ["id", "name", "first_id"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string", "enum": ["farm","village","forest","castle","admin"] },
          "first_id": { "type": "integer" }
        }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "description": "固定8层，index 0..7",
      "items": {
        "type": "object",
        "required": ["index", "name", "cells"],
        "properties": {
          "index": { "type": "integer", "minimum": 0, "maximum": 7 },
          "name": { "type": "string" },
          "cells": {
            "type": "array",
            "items": {
              "type": "array",
              "minItems": 3,
              "maxItems": 4,
              "items": [
                { "type": "integer", "description": "cell x (map coord)" },
                { "type": "integer", "description": "cell y (map coord)" },
                { "type": "integer", "description": "tile_id (>=0 set, -1 erase)" },
                { "type": "integer", "description": "optional alt tile" }
              ]
            }
          }
        }
      }
    },
    "entities": {
      "type": "array",
      "description": "6 类实体：npc/enemy/chest/checkpoint/portal/trigger",
      "items": {
        "type": "object",
        "required": ["id", "kind", "x", "y", "props"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["npc","enemy","chest","checkpoint","portal","trigger"] },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "props": { "type": "object" }
        }
      }
    },
    "objectives": {
      "type": "array",
      "description": "首项可选 {\"logic\":\"AND\"|\"OR\"}；其余每项 {id,type,data,reward}",
      "items": {
        "type": "object",
        "oneOf": [
          {
            "description": "组合逻辑声明（AND 需全部 / OR 任一项）",
            "required": ["logic"],
            "properties": { "logic": { "type": "string", "enum": ["AND", "OR"] } },
            "additionalProperties": false
          },
          {
            "description": "目标项（10 种处理器：REACH_AREA/DEFEAT_ENEMY/RECRUIT/OPEN_CHEST/TRIGGER/DIALOG/BOSS/AND/OR/NOT）",
            "required": ["id", "type"],
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["REACH_AREA","DEFEAT_ENEMY","RECRUIT","OPEN_CHEST","TRIGGER","DIALOG","BOSS","AND","OR","NOT"]
              },
              "data": { "type": "object" },
              "reward": { "type": "object", "description": "奖励：gold/unlock(items/skins)/items{prop:potion}" }
            }
          }
        ]
      }
    },
    "meta": {
      "type": "object",
      "description": "可选扩展字段：spawn / next_level / mode / min_rank / bounds / create_ts / author",
      "properties": {
        "spawn": { "type": "object", "properties": { "x": { "type": "number" }, "y": { "type": "number" } } },
        "next_level": { "type": "string" },
        "mode": { "type": "string", "enum": ["PVE","PVP","ARENA","STORY","HORDE"] },
        "min_rank": { "type": "integer", "minimum": 1 },
        "bounds": { "type": "object", "properties": {
          "x": { "type": "number" }, "y": { "type": "number" },
          "w": { "type": "number" }, "h": { "type": "number" } } },
        "create_ts": { "type": "string" },
        "author": { "type": "string" },
        "template_name": { "type": "string" }
      }
    }
  }
}
