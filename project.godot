; Engine configuration file.
; Godot 4.6.2 - Medieval Rebellion (V0.3 Combat Module)
; Iteration 3: 角色战斗实装

config_version=5

[application]

config/name="Medieval Rebellion"
config/description="2D横版跳跃动作 - 迭代3(V0.3): 角色战斗实装"
run/main_scene="res://scenes/test/V03_CombatArena.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

InputBus="*res://autoload/InputBus.gd"
GameEvents="*res://autoload/GameEvents.gd"
ConfigManager="*res://autoload/ConfigManager.gd"
ProgressFlags="*res://autoload/ProgressFlags.gd"
SaveSlotManager="*res://autoload/SaveSlotManager.gd"
LevelFlowController="*res://autoload/LevelFlowController.gd"
PickupSystem="*res://autoload/PickupSystem.gd"
AudioBus="*res://autoload/AudioBus.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

