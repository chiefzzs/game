2d_physics/layer_2="Companion"
2d_physics/layer_3="Enemy"
2d_physics/layer_4="Ground"
2d_physics/layer_5="Projectile"
2d_physics/layer_6="Pickup"
2d_physics/layer_7="Hazard"
